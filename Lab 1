<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Web Site</title>
    <style>
        body {
            font-family: Cambria, serif;
            font-size: 16px;
            background-color: #ffffff;
        }

        .box {
            border: 2px solid black;
            width: 500px;
            padding: 30px;
            margin: 40px auto;
            background-color: #d6d6d6;
        }

        h1 {
            text-align: center;
            margin-bottom: 10px;
        }

        .red-underline {
            color: rgb(250, 0, 0);
            text-decoration: underline;
            text-align: center;
            margin-bottom: 20px;
        }

        .content {
            display: flex;
            align-items: flex-start;
            gap: 20px;
        }

        .info {
            color: rgb(56, 151, 58);
        }

        .info p {
            margin: 5px 0;
        }

        .label {
            font-weight: bold;
        }

        img {
            width: 250px;
            height: 250px;
            border: 1px solid #830404;
        }
    </style>
</head>

<body>
    <div class="box">
        <h1>Welcome to my website</h1>
        <p class="red-underline">Dev Web</p>

        <div class="content">
            <div class="info">
                <p><span class="label">Full Name :</span> ayat errahmane</p>
                <p><span class="label">Age :</span> 21</p>
                <p><span class="label">Class :</span> 2ère Informatique</p>
                <p><span class="label">University :</span>  Hamma Lakhdar</p>
            </div>

            <img src="https://clipart-library.com/2024/nature-landscapes/nature-landscapes-2.jpg" width="400">
        </div>
    </div>
</body>
</html>
